{
  "manifest_version": 3,
  "name": "WhatsApp Logout Blocker",
  "version": "1.0",
  "description": "Prevents WhatsApp Web from logging out automatically in Chrome.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://*.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
